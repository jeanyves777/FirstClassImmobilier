// FirstClass Immobilier — SQLite for dev, Postgres for prod.
// Both providers share this schema; SQLite has no native enums / Json, so:
//   • enum-like columns are String (validated via Zod/const unions).
//   • bilingual text columns are String holding JSON {fr, en} (helpers in src/lib/zod/localized.ts).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "sqlite"
}

// ── Identity & access ──────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  phone           String?
  whatsapp        String?
  fullName        String
  passwordHash    String?
  locale          String    @default("fr")
  role            String    @default("VISITOR") // VISITOR BUYER PROSPECT APPLICANT STAFF ADMIN
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  sales         Sale[]         @relation("BuyerSales")
  agentSales    Sale[]         @relation("AgentSales")
  reservations  Reservation[]
  agentReservations Reservation[] @relation("AgentReservations")
  leads         Lead[]
  application   Application?
  chatThreads   ChatThread[]
  chatMessages  ChatMessage[]
  appointments  Appointment[]  @relation("UserAppointments")
  staffAppts    Appointment[]  @relation("StaffAppointments")
  notifications Notification[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ── Real-estate domain ─────────────────────────────────────────────────────

model Program {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String // LocalizedJSON
  tagline      String // LocalizedJSON
  description  String // LocalizedJSON
  type         String   @default("LOTISSEMENT") // TERRAIN MAISON LOTISSEMENT
  status       String   @default("ON_SALE") // DRAFT ON_SALE SOLD_OUT DELIVERED
  zone         String // Abidjan | Grand Abidjan | Intérieur | Extérieur
  featured     Boolean  @default(false)
  heroMediaId  String?
  catalogId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lots         Lot[]
  media        Media[]
  plans        Plan[]
  reservations Reservation[]
  sales        Sale[]
}

model Lot {
  id              String  @id @default(cuid())
  programId       String
  reference       String
  surfaceM2       Int
  priceFCFA       BigInt
  status          String  @default("available") // available | reserved | sold
  title           String? // LocalizedJSON (optional friendly title, e.g. "Villa T4")
  description     String? // LocalizedJSON
  highlights      String? // LocalizedJSON — short bullet summary
  features        String? // JSON array of amenities
  bedrooms        Int?
  bathrooms       Int?
  videoUrl        String? // direct video (mp4 / webm) or external URL
  virtualTourUrl  String? // Matterport / Kuula / YouTube embed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  program      Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  media        Media[]
  reservations Reservation[]
  sales        Sale[]
  appointments Appointment[]

  @@unique([programId, reference])
}

model Reservation {
  id              String   @id @default(cuid())
  userId          String
  programId       String
  lotId           String?
  assignedAgentId String?
  status          String   @default("pending") // pending | confirmed | cancelled
  note            String?
  createdAt       DateTime @default(now())

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  program       Program @relation(fields: [programId], references: [id])
  lot           Lot?    @relation(fields: [lotId], references: [id])
  assignedAgent User?   @relation("AgentReservations", fields: [assignedAgentId], references: [id])
}

model Sale {
  id                    String    @id @default(cuid())
  buyerId               String
  programId             String
  lotId                 String?
  assignedAgentId       String?
  stage                 String    @default("draft") // draft | contract-sent | signed | in-progress | acd-pending | completed | cancelled
  totalFCFA             BigInt
  signedAt              DateTime?
  acdIssuedAt           DateTime?
  acdDocumentId         String?
  constructionProgress  Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  buyer           User  @relation("BuyerSales", fields: [buyerId], references: [id])
  program         Program @relation(fields: [programId], references: [id])
  lot             Lot?    @relation(fields: [lotId], references: [id])
  assignedAgent   User?   @relation("AgentSales", fields: [assignedAgentId], references: [id])
  payments        Payment[]
  documents       Document[]
  milestones      Milestone[]
  requirements    DocumentRequirement[]
}

model Payment {
  id         String    @id @default(cuid())
  saleId     String
  amountFCFA BigInt
  dueAt      DateTime
  paidAt     DateTime?
  method     String?
  receiptId  String?
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

// ── Content (7 onglets) ────────────────────────────────────────────────────

model Page {
  id    String @id @default(cuid())
  slug  String @unique // values | vision | mission | products | bio
  title String // LocalizedJSON
  body  String // LocalizedJSON
}

model Service {
  id      String @id @default(cuid())
  order   Int    @default(0)
  title   String // LocalizedJSON
  blurb   String // LocalizedJSON
  body    String // LocalizedJSON
  imageId String?
}

model Partner {
  id     String  @id @default(cuid())
  name   String
  logoId String?
  url    String?
  order  Int     @default(0)
}

model Activity {
  id          String    @id @default(cuid())
  title       String // LocalizedJSON
  date        DateTime
  coverId     String?
  body        String // LocalizedJSON
  publishedAt DateTime?
  gallery     Media[]
}

model TeamMember {
  id       String @id @default(cuid())
  fullName String
  role     String // LocalizedJSON
  photoId  String?
  order    Int    @default(0)
}

model SiteStats {
  id               Int @id @default(1)
  yearsExperience  Int @default(8)
  satisfiedClients Int @default(350)
  projectsCount    Int @default(7)
  landsSold        Int @default(450)
  housesBuilt      Int @default(57)
  acdDelivered     Int @default(380)
  updatedAt        DateTime @updatedAt
}

// ── Leads, forms, chat, scheduler ──────────────────────────────────────────

model Lead {
  id              String   @id @default(cuid())
  userId          String?
  source          String // vos-avis | signup | a-la-une | ...
  payload         String // JSON
  status          String   @default("new") // new | contacted | qualified | lost | converted
  assignedStaffId String?
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Application {
  id        String   @id @default(cuid())
  userId    String?  @unique
  fullName  String
  email     String
  phone     String
  message   String
  resumeId  String?
  status    String   @default("received") // received | reviewing | interview | rejected | hired
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model ChatThread {
  id              String   @id @default(cuid())
  userId          String
  subject         String?
  status          String   @default("open") // open | pending | closed
  assignedStaffId String?
  updatedAt       DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [senderId], references: [id])
}

model Appointment {
  id           String   @id @default(cuid())
  userId       String?                // null for guest / pre-account requests
  guestName    String?
  guestEmail   String?
  guestPhone   String?
  staffId      String?
  purpose      String // visit-site | office-meeting | online-call | lot-visit
  source       String   @default("public-form") // public-form | portal | admin
  programId    String?
  lotId        String?
  scheduledAt  DateTime?              // may be null when prospect requests callback for scheduling
  preferredAt  DateTime?              // slot requested by the prospect before staff confirmation
  durationMin  Int      @default(45)
  status       String   @default("requested") // requested | booked | confirmed | cancelled | completed
  note         String?
  meetingUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User? @relation("UserAppointments", fields: [userId], references: [id])
  staff User? @relation("StaffAppointments", fields: [staffId], references: [id])
  lot   Lot?  @relation(fields: [lotId], references: [id])
}

model Notification {
  id      String    @id @default(cuid())
  userId  String
  kind    String
  payload String // JSON
  readAt  DateTime?
  sentAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Analytics ──────────────────────────────────────────────────────────────

model VisitorSession {
  id          String     @id @default(cuid())
  userId      String?
  anonymousId String
  ip          String?
  country     String?
  city        String?
  lat         Float?
  lng         Float?
  userAgent   String?
  referer     String?
  utm         String? // JSON
  startedAt   DateTime   @default(now())
  pageViews   PageView[]
}

model PageView {
  id         String         @id @default(cuid())
  sessionId  String
  path       String
  locale     String
  durationMs Int?
  createdAt  DateTime       @default(now())
  session    VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ── Shared assets ──────────────────────────────────────────────────────────

model Media {
  id         String    @id @default(cuid())
  kind       String    @default("image") // image | video | pdf | tour
  url        String
  alt        String? // LocalizedJSON
  order      Int       @default(0)
  programId  String?
  lotId      String?
  activityId String?

  program  Program?  @relation(fields: [programId], references: [id])
  lot      Lot?      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id])
}

model Document {
  id            String   @id @default(cuid())
  kind          String
  url           String
  ownerUserId   String?
  saleId        String?
  applicationId String?
  createdAt     DateTime @default(now())

  sale Sale? @relation(fields: [saleId], references: [id])
}

model Plan {
  id        String  @id @default(cuid())
  programId String
  label     String // LocalizedJSON
  fileUrl   String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model Milestone {
  id        String    @id @default(cuid())
  saleId    String
  label     String // LocalizedJSON
  reachedAt DateTime?
  photoId   String?
  sale      Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model DocumentRequirement {
  id         String    @id @default(cuid())
  saleId     String
  kind       String    // contract | id | proof-address | down-payment | acd | final-deed | ...
  label      String    // LocalizedJSON
  status     String    @default("required") // required | uploaded | approved | rejected
  documentId String?   // link to uploaded Document
  note       String?
  reviewedById String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId, status])
}
